---

helmDefaults:
  cleanupOnFail: true
  wait: true
  waitForJobs: true

releases:
  - name: cilium
    namespace: kube-system
    chart: oci://quay.io/cilium/charts/cilium
    version: 1.19.3
    values: ['./templates/values.yaml.gotmpl']

  - name: coredns
    namespace: kube-system
    chart: oci://ghcr.io/coredns/charts/coredns
    version: 1.45.2
    values: ['./templates/values.yaml.gotmpl']
    needs: ['kube-system/cilium']

  #% if spegel_enabled %#
  - name: spegel
    namespace: kube-system
    chart: oci://ghcr.io/spegel-org/helm-charts/spegel
    version: 0.7.0
    values: ['./templates/values.yaml.gotmpl']
    needs: ['kube-system/coredns']
  #% endif %#

  - name: metrics-server
    namespace: kube-system
    chart: oci://ghcr.io/home-operations/charts-mirror/metrics-server
    version: 3.13.0
    values: ['./templates/values.yaml.gotmpl']
    #% if spegel_enabled %#
    needs: ['kube-system/spegel']
    #% else %#
    needs: ['kube-system/coredns']
    #% endif %#

  #% if reloader_enabled %#
  - name: reloader
    namespace: kube-system
    chart: oci://ghcr.io/stakater/charts/reloader
    version: 2.2.11
    values: ['./templates/values.yaml.gotmpl']
    #% if spegel_enabled %#
    needs: ['kube-system/spegel']
    #% else %#
    needs: ['kube-system/coredns']
    #% endif %#
  #% endif %#

  #% if certmanager_enabled %#
  - name: cert-manager
    namespace: cert-manager
    chart: oci://quay.io/jetstack/charts/cert-manager
    version: v1.20.2
    values: ['./templates/values.yaml.gotmpl']
    #% if spegel_enabled %#
    needs: ['kube-system/spegel']
    #% else %#
    needs: ['kube-system/coredns']
    #% endif %#
  #% endif %#

  #% if flux_enabled %#
  - name: flux-operator
    namespace: flux-system
    chart: oci://ghcr.io/controlplaneio-fluxcd/charts/flux-operator
    version: 0.47.0
    values: ['./templates/values.yaml.gotmpl']
    #% if spegel_enabled %#
    needs: ['kube-system/spegel']
    #% else %#
    needs: ['kube-system/coredns']
    #% endif %#

  - name: flux-instance
    namespace: flux-system
    chart: oci://ghcr.io/controlplaneio-fluxcd/charts/flux-instance
    version: 0.47.0
    values: ['./templates/values.yaml.gotmpl']
    needs: ['flux-system/flux-operator']
  #% endif %#
