apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: hubble-ui
spec:
  parentRefs:
    - name: envoy-internal
      namespace: network
      sectionName: http
  hostnames:
    - hubble.kube.ag
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: hubble-ui
          port: 80
      sessionPersistence:
        type: Cookie
        sessionName: HUBBLE_STICKY_SESSION
        absoluteTimeout: 12h
        cookieConfig:
          lifetimeType: Permanent
