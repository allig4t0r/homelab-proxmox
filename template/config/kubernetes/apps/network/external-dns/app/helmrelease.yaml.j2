---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: external-dns
spec:
  chartRef:
    kind: OCIRepository
    name: external-dns
  interval: 1h
  values:
    provider: pihole
    env:
      - name: EXTERNAL_DNS_PIHOLE_PASSWORD
        valueFrom:
          secretKeyRef:
            name: &secret external-dns-secret
            key: pihole-password
    extraArgs:
      - --crd-source-apiversion=externaldns.k8s.io/v1alpha1
      - --crd-source-kind=DNSEndpoint
      - --gateway-name=envoy-internal
      - --pihole-server=http://#{ pihole_server }#
      - --pihole-tls-skip-verify
      - --pihole-api-version=6
    triggerLoopOnEvent: true
    policy: sync
    registry: noop
    sources: ["crd", "gateway-httproute"]
    domainFilters: ["#{ cluster_domain }#"]
    serviceMonitor:
      enabled: true
    podAnnotations:
      secret.reloader.stakater.com/reload: *secret
